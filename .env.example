# Copy to .env (same directory as docker-compose.yml). Docker Compose loads .env automatically.
# Do not commit .env.
#
# LorBeeOS (optional image product): path layout — see docs/lorbeeos-paths.md.

# Directory that contains docker-compose.yml, mosquitto/, zigbee2mqtt/, nodered/, lora/ (default: this repo).
LORBEE_STACK_ROOT=.

# Host path to merged Zigbee JSON (mounted at /data/snapshot in nodered + lora). Use an absolute path on LorBeeOS, e.g. /var/lib/lorbee/snapshot
LORBEE_SNAPSHOT_HOST=./data/snapshot

# Timezone for all containers (TZ)
TZ=Europe/Zagreb

# Host user:group for Node-RED (must match numeric uid:gid of the owner of ./nodered/data).
# Default 1000:1000 matches many "pi" images; your user may differ — run: id -u && id -g
NODE_RED_USER=1000:1000

# Logical edge id (sanitized for MQTT topic). Use a unique value per Pi if several edges share one broker.
# Retained topic: lorbee/edges/<EDGE_ID>/sensors/latest
EDGE_ID=default

# Zigbee coordinator: inside the container the device is always mapped as /dev/ttyUSB0.
# On the HOST, set a stable path (best: /dev/serial/by-id/...). Plain /dev/ttyUSB0 often
# changes after reboot. Run: ls -la /dev/serial/by-id/
# First-time setup can fill this for you: bash scripts/setup-first-run.sh
# If unset or wrong, use: make up-safe  (resolves/waits for USB, then starts the stack)
ZIGBEE_SERIAL_DEVICE=/dev/ttyUSBx # Replace with your by-id path, or remove after setup / use make up-safe
# Optional: scripts/restart-zigbee2mqtt-when-ready.sh and make up-safe (seconds)
# ZIGBEE_SERIAL_WAIT_SEC=180
# ZIGBEE_SERIAL_SETTLE_SEC=5
# Post-up zigbee2mqtt restart: default in stack-after-boot.sh is OFF (single start after USB wait).
# Set to 1 only if a specific coordinator needs a delayed restart after boot.
# ZIGBEE2MQTT_POST_UP_RESTART=1
# ZIGBEE2MQTT_PRE_RESTART_SLEEP_SEC=45
#
# Pi cold boot: install systemd timer once — sudo bash scripts/install-zigbee-boot-timer.sh (see docs/pi-cold-boot.md).
# That helper also runs LoRa if either is set:
# COMPOSE_PROFILES=lora
# LORBEE_LORA_ON_BOOT=1
#
# Optional — only used by scripts/setup-first-run.sh --yes (not read by Docker): patch Zigbee2MQTT YAML
# LORBEE_ZIGBEE_CHANNEL=20
# LORBEE_ZIGBEE_ADAPTER=zstack
