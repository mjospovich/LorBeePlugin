# Copy to keys.env (same directory). keys.env is gitignored — contains secrets.
# One Raspberry Pi = one ChirpStack LoRaWAN device (unique DevEUI/AppKey per Pi).
# Create the device in ChirpStack first, then paste keys here — lora/README.md
#
# Hardware (optional): run from repo root  bash scripts/setup-first-run.sh  and answer
# “LoRaWAN radio” to write RFM_SPI_CHANNEL, RFM_PIN_CS, RFM_PIN_DIO0, RFM_PIN_RST,
# LORAWAN_REGION, LORAWAN_SUB_BAND, LORAWAN_UPLINK_INTERVAL_SEC here (they override
# lora/chirpstack-node/config.yaml inside the container).

# 16 hex chars — DevEUI from ChirpStack (or your own, registered there)
LORAWAN_DEV_EUI=0102030405060708

# JoinEUI (ex-AppEUI). All zeros is fine for many private networks.
LORAWAN_JOIN_EUI=0000000000000000

# 32 hex chars — Application key from ChirpStack
LORAWAN_APP_KEY=0102030405060708090A0B0C0D0E0F10

# LoRaWAN 1.1: set NWK_KEY from ChirpStack. For LoRaWAN 1.0.x omit this line
# (the node copies APP_KEY into the network key slot).

# Optional overrides (normally set in config.yaml): LORAWAN_REGION, LORAWAN_SUB_BAND,
# LORAWAN_UPLINK_INTERVAL_SEC, RFM_SPI_CHANNEL, RFM_PIN_CS, RFM_PIN_DIO0, RFM_PIN_RST
# Packed payload: LORAWAN_PAYLOAD_FORMAT=legacy|packed, PAYLOAD_INCLUDE_STATUS=0|1, PAYLOAD_MAX_BYTES=222
# Seconds between OTAA retries if no Join-Accept (default 60). Stops Docker crash-looping.
# LORAWAN_JOIN_RETRY_SEC=60
#
# Packed + Docker: LoRa starts before Node-RED merges Zigbee into latest.json — avoid first-uplink race:
# LORAWAN_STARTUP_GRACE_SEC=30   # delay after join before first read (0 = off)
# LORAWAN_SNAPSHOT_RETRY_SEC=30   # if uplink skipped (missing device/file), retry after this (not full interval); project .env + docker-compose overrides this file
