# Local overrides (see .env.example)
.env

# Zigbee2MQTT runtime (secrets + state)
zigbee2mqtt/data/configuration.yaml
zigbee2mqtt/data/state.json
zigbee2mqtt/data/database.db*
zigbee2mqtt/data/coordinator_backup.json
zigbee2mqtt/data/log/
zigbee2mqtt/data/migration*.log
zigbee2mqtt/data/configuration_backup*.yaml

# LorBee merged snapshot (canonical location)
data/snapshot/*.json

# LoRaWAN OTAA persisted session (RadioLib nonces + session buffers)
data/lorawan-state/*
!data/lorawan-state/.gitkeep

# Node-RED runtime (editor state + secrets — recreated on first container start)
nodered/data/flows_cred.json
nodered/data/*.backup
nodered/data/.config*.backup
nodered/data/.config.nodes.json
nodered/data/.config.runtime.json
nodered/data/.config.users.json

# Duplicate / archive flows (canonical: nodered/data/flows.json)
nodered/flows/

# Mosquitto persistence (broker DB at runtime; directory kept via .gitkeep)
mosquitto/data/*
!mosquitto/data/.gitkeep

# LoRaWAN OTAA secrets (see lora/chirpstack-node/keys.env.example)
lora/chirpstack-node/keys.env

# LoRa node runtime (often contains site-specific Zigbee IEEEs in payload.entries — use config.example.yaml)
lora/chirpstack-node/config.yaml

# RadioLib clone for host builds (optional)
lora/chirpstack-node/RadioLib/

# Python
__pycache__/
*.pyc

# OS
.DS_Store
Thumbs.db
nodered/data/snapshot/latest.json
